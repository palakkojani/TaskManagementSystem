@model TaskManagementSystem.Models.User

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow">

                <div class="card-header bg-success text-white">
                    <h3>Register</h3>
                </div>

                <div class="card-body">

                    <form method="post">

                        <div class="mb-3">
                            <label>Name</label>

                            <input asp-for="Name"
                                   class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label>Email</label>

                            <input asp-for="Email"
                                   class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label>Password</label>

                            <input asp-for="Password"
                                   type="password"
                                   class="form-control" />
                        </div>

                        <button type="submit"
                                class="btn btn-success">
                            Register
                        </button>

                        <a asp-action="Login"
                           class="btn btn-primary">
                            Login
                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>